From 575a622d00e2f912cd62ce114b30cacc42e3e6fd Mon Sep 17 00:00:00 2001
From: "copilot-swe-agent[bot]" <198982749+Copilot@users.noreply.github.com>
Date: Thu, 23 Apr 2026 09:27:17 +0000
Subject: [PATCH] fix(pr300): remove unused PLAYER_SPRITE_KEY import, fix
 spritesheet type in loaderror, frame 0 for stub texture, fix CREDITS sheet
 dimensions

Co-authored-by: wasabali <60469868+wasabali@users.noreply.github.com>
---
 assets/sprites/CREDITS.md | 6 ++++--
 src/scenes/BootScene.js   | 4 ++--
 src/scenes/WorldScene.js  | 5 ++++-
 3 files changed, 10 insertions(+), 5 deletions(-)

diff --git a/assets/sprites/CREDITS.md b/assets/sprites/CREDITS.md
index 8e0f56f..d9dc050 100644
--- a/assets/sprites/CREDITS.md
+++ b/assets/sprites/CREDITS.md
@@ -10,8 +10,10 @@ sourced from the **Ninja Adventure Asset Pack** by Robert and Pixel-Boy.
 
 ### What's included
 
-Each character sprite sheet is a 4-direction walk-cycle sheet (96 × 128 px at base 1×,
-upscaled 3× to 288 × 384 px for the 48 px tile size used by Cloud Quest).
+Each character sprite sheet sources from Ninja Adventure (16 × 16 px per frame native).
+After the 3× nearest-neighbor upscale, each frame becomes 48 × 48 px — matching `CONFIG.TILE_SIZE`.
+The full sheet dimensions depend on the number of directions and animation frames per character;
+`BootScene` loads them with `frameWidth: 48, frameHeight: 48`.
 
 Sprite sheets live in `assets/sprites/characters/` and are named by archetype:
 
diff --git a/src/scenes/BootScene.js b/src/scenes/BootScene.js
index e0a12ea..71ccd83 100644
--- a/src/scenes/BootScene.js
+++ b/src/scenes/BootScene.js
@@ -1,6 +1,6 @@
 import Phaser from 'phaser'
 import { getAllBgm } from '#data/audio.js'
-import { getAllSpriteKeys, PLAYER_SPRITE_KEY } from '#data/trainers.js'
+import { getAllSpriteKeys } from '#data/trainers.js'
 
 export class BootScene extends Phaser.Scene {
   constructor() {
@@ -21,7 +21,7 @@ export class BootScene extends Phaser.Scene {
     this.load.on('loaderror', (file) => {
       const isOptionalBgm    = file?.type === 'audio' && optionalBgmKeys.has(file.key)
       const isOptionalLoopJson = file?.type === 'json' && file.key === 'bgmLoopPoints'
-      const isOptionalSprite = file?.type === 'image' && optionalSpriteKeys.has(file.key)
+      const isOptionalSprite = file?.type === 'spritesheet' && optionalSpriteKeys.has(file.key)
       if (isOptionalBgm || isOptionalLoopJson || isOptionalSprite) {
         console.warn(`[BootScene] Optional asset unavailable, continuing without it: ${file?.type}:${file?.key}`)
         return
diff --git a/src/scenes/WorldScene.js b/src/scenes/WorldScene.js
index 6c5acdb..c58da3d 100644
--- a/src/scenes/WorldScene.js
+++ b/src/scenes/WorldScene.js
@@ -338,7 +338,10 @@ export class WorldScene extends BaseScene {
     const playerTextureKey = this.textures.exists(PLAYER_SPRITE_KEY)
       ? PLAYER_SPRITE_KEY
       : 'player'
-    this._player = this.physics.add.sprite(startX, startY, playerTextureKey, 1)
+    // Only pass frame index 1 (idle-down) when using the walk-cycle spritesheet.
+    // The stub 'player' texture is a single-frame image — frame 0.
+    const playerFrame = playerTextureKey === PLAYER_SPRITE_KEY ? 1 : 0
+    this._player = this.physics.add.sprite(startX, startY, playerTextureKey, playerFrame)
     this._player.setDepth(CHAR_DEPTH)
 
     const persistedSpawn = persistPlayerTile(spawnTileX, spawnTileY)
