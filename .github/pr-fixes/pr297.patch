diff --git a/scripts/upscale-assets.js b/scripts/upscale-assets.js
index 4485ca7..ed2f45c 100644
--- a/scripts/upscale-assets.js
+++ b/scripts/upscale-assets.js
@@ -59,11 +59,41 @@ const INPUT  = path.resolve(ROOT, args.input)
 const OUTPUT = path.resolve(ROOT, args.output)
 const SCALE  = args.scale
 
+// Validate --scale: must be a finite positive integer
+if (!Number.isFinite(SCALE) || !Number.isInteger(SCALE) || SCALE < 1) {
+  console.error(`--scale must be a positive integer, got: ${args.scale}`)
+  process.exit(1)
+}
+
 if (!fs.existsSync(INPUT)) {
   console.error(`Input directory not found: ${INPUT}`)
   process.exit(1)
 }
 
+if (!fs.statSync(INPUT).isDirectory()) {
+  console.error(`Input path is not a directory: ${INPUT}`)
+  process.exit(1)
+}
+
+if (fs.existsSync(OUTPUT) && !fs.statSync(OUTPUT).isDirectory()) {
+  console.error(`Output path exists but is not a directory: ${OUTPUT}`)
+  process.exit(1)
+}
+
+// Guard against OUTPUT being the same as or nested inside INPUT
+function isNestedOrEqual(parentPath, childPath) {
+  const rel = path.relative(parentPath, childPath)
+  return rel === '' || (!rel.startsWith('..') && !path.isAbsolute(rel))
+}
+if (isNestedOrEqual(INPUT, OUTPUT)) {
+  console.error(
+    `Output directory must not be the same as or inside the input directory.\n` +
+    `  input:  ${INPUT}\n` +
+    `  output: ${OUTPUT}`,
+  )
+  process.exit(1)
+}
+
