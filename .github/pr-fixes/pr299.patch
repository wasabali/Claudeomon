--- a/docs/wiki/audio.md
+++ b/docs/wiki/audio.md
@@ -8,6 +8,9 @@ Cloud Quest uses real sound effects and background music to make every CLI comma
 
 Each region and battle type has a dedicated BGM track. Tracks loop seamlessly.
 
+> **Note:** The Track IDs in this table are audio registry keys from `src/data/audio.js`, not region IDs.
+> Multiple regions may share the same track. WorldScene will implement a region ID → track ID mapping at runtime.
+
 ### Overworld Tracks
 
 | Track ID | Where It Plays | Volume |
diff --git a/docs/wiki/world-map.md b/docs/wiki/world-map.md
index 2e1b644..0fa5281 100644
--- a/docs/wiki/world-map.md
+++ b/docs/wiki/world-map.md
@@ -6,6 +6,10 @@ Cloud Quest's world is divided into regions, each themed around a different doma
 
 ## Region Overview
 
+> **Note:** The BGM Track column lists audio registry track IDs from `src/data/audio.js` — not region IDs.
+> Multiple regions share the same track (e.g. `cloud_citadel` covers Staging Valley, Production Plains, Security Vault, Architecture District, Azure Town, and The Cloud Console).
+> WorldScene will implement the region ID → track ID mapping at runtime.
+
 | # | Region | Domain Focus | Act | Gym? | BGM Track | Description |
 |---|---|---|---|---|---|---|
 | 1 | **Localhost Town** | — | Prologue/1 | — | `localhost_town` | Starting village. Professor Pedersen's lab, Old Margaret's bakery, your apartment. Safe zone. |
diff --git a/src/scenes/BootScene.js b/src/scenes/BootScene.js
index a7daeee..8821bba 100644
--- a/src/scenes/BootScene.js
+++ b/src/scenes/BootScene.js
@@ -28,12 +28,12 @@ export class BootScene extends Phaser.Scene {
 
     // Load BGM tracks — OGG primary, MP3 fallback for browser coverage.
     for (const bgm of bgmTracks) {
-      this.load.audio(bgm.id, [bgm.file, bgm.file.replace('.ogg', '.mp3')])
+      this.load.audio(bgm.id, [bgm.file, bgm.file.replace(/\.ogg$/, '.mp3')])
     }
 
     // Load SFX files — OGG primary, MP3 fallback for browser coverage.
     for (const sfx of sfxPresets) {
-      this.load.audio(sfx.id, [sfx.file, sfx.file.replace('.ogg', '.mp3')])
+      this.load.audio(sfx.id, [sfx.file, sfx.file.replace(/\.ogg$/, '.mp3')])
     }
 
     this.load.json('bgmLoopPoints', 'assets/audio/bgm-loop-points.json')
